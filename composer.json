{
    "name": "anishanilkumar/phpresellerclub",
    "description": "A modern, PSR-18 based PHP abstraction for the ResellerClub domain reseller API.",
    "type": "library",
    "keywords": ["resellerclub", "domain", "reseller", "api", "psr-18", "logicboxes"],
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Anish Sheela",
            "email": "aneesh.nl@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1 || ^2.0",
        "guzzlehttp/guzzle": "^7.8",
        "guzzlehttp/psr7": "^2.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5 || ^12.0",
        "phpstan/phpstan": "^2.0",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "autoload": {
        "psr-4": {
            "Resellerclub\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Resellerclub\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html build/coverage --coverage-clover build/logs/clover.xml",
        "phpstan": "phpstan analyse",
        "cs:check": "phpcs",
        "cs:fix": "phpcbf",
        "check": [
            "@cs:check",
            "@phpstan",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
